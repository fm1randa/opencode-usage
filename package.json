{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "openbar",
  "version": "0.1.0",
  "type": "module",
  "description": "CodexBar within opencode.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fm1randa/openbar"
  },
  "keywords": ["opencode", "plugin", "quota", "sidebar", "codex", "copilot", "zai"],
  "exports": {
    "./server": {
      "import": "./server.ts",
      "config": {
        "enabled": true
      }
    },
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "sidebar": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.13"
  },
  "scripts": {
    "test": "bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
