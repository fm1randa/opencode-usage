{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "openbar",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode sidebar quota widget for Codex, GitHub Copilot, and z.ai.",
  "exports": {
    "./server": {
      "import": "./server.ts",
      "config": {
        "enabled": true
      }
    },
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "sidebar": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.13"
  },
  "scripts": {
    "test": "bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
